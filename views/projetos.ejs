<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" type='text/css' href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <title>Projetos</title>
</head>

<body class="bg-gray-300">
    <header>
        <nav class="max-w-6xl mx-auto flex h-20 items-center justify-between px-6 lg:px-10">
            <figure class="hover:scale-110 transition duration-500"> 
                <img src="/img/hugo_logo.svg" width="200px" alt="Logo"> 
            </figure>
            
            <div class="flex items-center gap-2">
                <div class="hover:bg-gray-400/30 transition duration-500 rounded-lg group relative flex flex-col items-center p-2">
                    <a href="/">
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-8 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </a>
                    <span class="font-bold absolute top-full mt-2 scale-0 rounded bg-gray-700 p-2 text-xs text-white transition-all group-hover:scale-100 z-50 whitespace-nowrap">Início</span>
                </div>

                <div class="hover:bg-gray-400/30 transition duration-500 rounded-lg group relative flex flex-col items-center p-2">
                    <a href="/projetos">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 text-gray-700">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                        </svg>
                    </a>
                    <span class="font-bold absolute top-full mt-2 scale-0 rounded bg-gray-700 p-2 text-xs text-white transition-all group-hover:scale-100 z-50 whitespace-nowrap">Meus Projetos</span>
                </div>

                <div class="hover:bg-gray-400/30 transition duration-500 rounded-lg group relative flex flex-col items-center p-2">
                    <a href="/certificacoes">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 text-gray-700">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                        </svg>
                    </a>
                    <span class="font-bold absolute top-full mt-2 scale-0 rounded bg-gray-700 p-2 text-xs text-white transition-all group-hover:scale-100 z-50 whitespace-nowrap">Certificações</span>
                </div>
            </div>
        </nav>
    </header>

    <main class="px-6 lg:px-20 max-w-7xl mx-auto" id="projetos-container">
       
        <% if (logado) { %>
        <div class="max-w-2xl mx-auto mt-10">
            <div class="bg-white rounded-lg shadow-lg p-6">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">Adicionar Novo Projeto</h2>
                <form action="/projetos" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-gray-700 font-bold mb-2" for="titulo">Título do Projeto</label>
                        <input type="text" id="titulo" name="titulo" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-bold mb-2" for="descricao">Descrição</label>
                        <textarea id="descricao" name="descricao" rows="3" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500"></textarea>
                    </div>
                    <div>
                        <label class="block text-gray-700 font-bold mb-2" for="tecnologias">Tecnologias (vírgula)</label>
                        <input type="text" id="tecnologias" name="tecnologias" placeholder="React, Node.js" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-bold mb-2" for="link">Link</label>
                        <input type="url" id="link" name="link" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                    </div>
                    <button type="submit" class="w-full bg-gray-700 text-white font-bold py-2 px-4 rounded-lg hover:bg-gray-800 transition duration-300">Adicionar Projeto</button>
                </form>
            </div>
        </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-10">
            <% projetos.forEach((projeto, index) => { %>
            
            <div class="relative">
                <input type="checkbox" id="modal-<%= index %>" class="hidden peer">
                
                <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm z-50 hidden peer-checked:flex items-center justify-center p-4">
                    <label for="modal-<%= index %>" class="absolute inset-0 cursor-default"></label>
                    
                    <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6 relative z-10">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-xl font-bold text-gray-800">Editar: <%= projeto.titulo %></h3>
                            <label for="modal-<%= index %>" class="cursor-pointer text-gray-400 hover:text-red-500 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </label>
                        </div>
                        
                        <form action="/projetos/put?_method=PUT" method="POST" class="space-y-4">
                            <input type="hidden" name="titulo" value="<%= projeto.titulo %>">
                            <div>
                                <label class="block text-gray-700 font-bold mb-1">Descrição</label>
                                <textarea name="descricao" rows="3" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-gray-500 outline-none"><%= projeto.descricao %></textarea>
                            </div>
                            <div>
                                <label class="block text-gray-700 font-bold mb-1">Tecnologias</label>
                                <input type="text" name="tecnologias" value="<%= projeto.tecnologias ? projeto.tecnologias.join(', ') : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-gray-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-gray-700 font-bold mb-1">Link</label>
                                <input type="url" name="link" required value="<%= projeto.link %>" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-gray-500 outline-none">
                            </div>
                            <button type="submit" class="w-full bg-blue-600 text-white font-bold py-2 rounded-lg hover:bg-blue-700 transition">Salvar Alterações</button>
                        </form>
                    </div>
                </div>

                <div class="bg-white h-full flex flex-col rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300">
                    <div class="p-6 flex flex-col h-full">
                        <h3 class="text-xl font-bold text-gray-800 mb-2"><%= projeto.titulo %></h3>
                        <p class="text-gray-600 mb-4 flex-grow"><%= projeto.descricao %></p>
                        
                        <% if (projeto.tecnologias && projeto.tecnologias.length > 0) { %>
                        <div class="flex flex-wrap gap-2 mb-4">
                            <% projeto.tecnologias.forEach(tech => { %>
                            <span class="bg-gray-100 text-gray-600 text-[10px] uppercase font-bold px-2 py-1 rounded">
                                <%= tech %>
                            </span>
                            <% }) %>
                        </div>
                        <% } %>
                        
                        <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-100">
                            <a href="<%= projeto.link %>" target="_blank" class="text-gray-700 hover:text-black font-bold flex items-center gap-1 text-sm">
                                Ver Projeto
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                            </a>
                            
                            <% if (logado) { %>
                            <div class="flex gap-3">
                                <label for="modal-<%= index %>" class="text-blue-600 hover:text-blue-800 cursor-pointer p-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </label>
                                
                                <form action="/projetos/delete?_method=DELETE" method="POST" onsubmit="return confirm('Excluir este projeto?');">
                                    <input type="hidden" name="titulo" value="<%= projeto.titulo %>">
                                    <button type="submit" class="text-red-600 hover:text-red-800 p-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </main>
    
    <footer class="pb-20 mt-20">
         <p class="text-center font-bold text-gray-500 uppercase text-xs tracking-widest">© 2026 Hugo Leonardo</p>
    </footer>
</body>
</html>