<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" type='text/css' href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <title>Certificações</title>
</head>

<body class="bg-gray-300">
    <header>
        <nav class="max-w-6xl mx-auto flex h-20 items-center justify-between px-6 lg:px-10">
            <figure class="hover:scale-110 transition duration-500"> 
                <img src="./img/hugo_logo.svg" width="200px" alt="Logo"> 
            </figure>
            
            <div class="flex items-center gap-2">
                <div class="hover:bg-gray-400/30 transition duration-500 rounded-lg group relative flex flex-col items-center p-2">
                    <% if (logado) { %>
                      
                    <% } else { %>
                        
                    <% } %>
                </div>

                <div class="hover:bg-gray-400/30 transition duration-500 rounded-lg group relative flex flex-col items-center p-2">
                    <a href="/">
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-8 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </a>
                    <span class="font-bold absolute top-full mt-2 scale-0 rounded bg-gray-700 p-2 text-xs text-white transition-all group-hover:scale-100 z-50 whitespace-nowrap">
                        Início
                    </span>
                </div>

                <div class="hover:bg-gray-400/30 transition duration-500 rounded-lg group relative flex flex-col items-center p-2">
                    <a href="/projetos">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 text-gray-700">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                        </svg>
                    </a>
                    <span class="font-bold absolute top-full mt-2 scale-0 rounded bg-gray-700 p-2 text-xs text-white transition-all group-hover:scale-100 z-50 whitespace-nowrap">
                        Meus Projetos
                    </span>
                </div>

                <div class="hover:bg-gray-400/30 transition duration-500 rounded-lg group relative flex flex-col items-center p-2">
                    <a href="/certificacoes">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 text-gray-700">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                        </svg>
                    </a>
                    <span class="font-bold absolute top-full mt-2 scale-0 rounded bg-gray-700 p-2 text-xs text-white transition-all group-hover:scale-100 z-50 whitespace-nowrap">
                       Certificações
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <main class="px-6 lg:px-100">
        <% if (logado) { %>
        <!-- FORMULÁRIO PARA ADICIONAR CERTIFICAÇÃO -->
        <div class="max-w-2xl mx-auto mt-10 mb-10">
            <div class="bg-white rounded-lg shadow-lg p-6">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">Adicionar Nova Certificação</h2>
                <form action="/certificacoes" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-gray-700 font-bold mb-2" for="nome">Nome da Certificação</label>
                        <input type="text" id="nome" name="nome" required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-bold mb-2" for="instituicao">Instituição</label>
                        <input type="text" id="instituicao" name="instituicao" required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-bold mb-2" for="status">Status</label>
                        <select id="status" name="status" required
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                            <option value="">Selecione...</option>
                            <option value="Concluido">Concluído</option>
                            <option value="Cursando">Cursando</option>
                        </select>
                    </div>
                    <button type="submit" 
                            class="w-full bg-gray-700 text-white font-bold py-2 px-4 rounded-lg hover:bg-gray-800 transition duration-300">
                        Adicionar Certificação
                    </button>
                </form>
            </div>
        </div>
        <% } %>

        <!-- Lista de Certificações -->
        <section class="flex flex-col">
            <% if (certificacoes && certificacoes.length > 0) { %>
                <% for(let i = 0; i < certificacoes.length; i++) { %>
                
                <!-- MODAL PARA EDITAR CERTIFICAÇÃO -->
                <div class="relative">
                    <input type="checkbox" id="modal-<%= i %>" class="hidden peer">
                    
                    <div class="fixed inset-0 bg-gray-500 bg-opacity-50 z-50 hidden peer-checked:flex items-center justify-center">
                        <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4 p-6">
                            <div class="flex justify-between items-center mb-4">
                                <h3 class="text-2xl font-bold text-gray-800">Editar Certificação</h3>
                                <label for="modal-<%= i %>" class="cursor-pointer text-gray-500 hover:text-gray-700">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </label>
                            </div>
                            
                            <form action="/certificacoes/put?_method=PUT" method="POST" class="space-y-4">
                                <input type="hidden" name="nomeOriginal" value="<%= certificacoes[i].nome %>">
                                <input type="hidden" name="nome" value="<%= certificacoes[i].nome %>">
                                
                                <div>
                                    <label class="block text-gray-700 font-bold mb-2" for="instituicao-<%= i %>">Instituição</label>
                                    <input type="text" id="instituicao-<%= i %>" name="instituicao" 
                                           value="<%= certificacoes[i].instituicao %>" required
                                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                                </div>
                                
                                <div>
                                    <label class="block text-gray-700 font-bold mb-2" for="status-<%= i %>">Status</label>
                                    <select id="status-<%= i %>" name="status" required
                                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-gray-500">
                                        <option value="Concluido" <%= certificacoes[i].status === 'Concluido' ? 'selected' : '' %>>Concluído</option>
                                        <option value="Cursando" <%= certificacoes[i].status === 'Cursando' ? 'selected' : '' %>>Cursando</option>
                                    </select>
                                </div>
                                
                                <button type="submit" 
                                        class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-700 transition duration-300">
                                    Salvar Alterações
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- CARD DA CERTIFICAÇÃO -->
                    <div class="bg-white mx-auto w-full max-w-4xl grid grid-cols-1 md:grid-cols-3 shadow-2xl border-2 rounded-xl border-dark-strong px-5 py-4 <%= i > 0 ? 'mt-4' : '' %>">
                        <div class="md:col-span-3 py-2 flex justify-between items-center">
                            <h1 class="inline-block font-bold bg-blue-500 text-white md:text-2xl rounded-full px-5 py-1 text-center">
                                <%= certificacoes[i].nome %>
                            </h1>
                            
                            <% if (logado) { %>
                            <div class="flex gap-2">
                                <!-- BOTÃO EDITAR (ABRE MODAL) -->
                                <label for="modal-<%= i %>" class="text-blue-600 hover:text-blue-800 cursor-pointer">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </label>
                                
                                <!-- BOTÃO DELETAR -->
                                <form action="/certificacoes/delete?_method=DELETE" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir esta certificação?');">
                                    <input type="hidden" name="nome" value="<%= certificacoes[i].nome %>">
                                    <button type="submit" class="text-red-600 hover:text-red-800">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                            <% } %>
                        </div>
                        
                        <div class="font-bold text-sm text-dark-strong rounded-lg py-5">
                            Status: 
                            <span class="<%= certificacoes[i].status === 'Concluido' ? 'text-green-600' : 'text-yellow-600' %>">
                                <%= certificacoes[i].status === 'Concluido' ? 'Concluído' : 'Cursando' %>
                            </span>
                        </div>
                        
                        <div class="md:col-span-2 py-7 flex items-center justify-center">
                            <p class="font-semibold text-gray-700 text-lg"><%= certificacoes[i].instituicao %></p>
                        </div>
                    </div>
                </div>
                <% } %>
            <% } else { %>
                <div class="bg-white mx-auto max-w-4xl shadow-2xl border-2 rounded-xl p-10 text-center">
                    <p class="text-gray-500 text-lg">Nenhuma certificação encontrada.</p>
                </div>
            <% } %>
        </section>
    </main>
            
    <footer id="projetos" class="px-6 md:px-35 pb-20 mt-20">
        <p class="text-center pb-10 font-bold text-gray-600 uppercase text-xs tracking-widest">© 2026 Hugo Leonardo</p>
    </footer>
</body>

</html>